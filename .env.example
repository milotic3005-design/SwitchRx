# ANTHROPIC_API_KEY: Required for Claude (Anthropic) API calls.
# For Next.js client-side access (this app calls Claude directly from the
# browser), use NEXT_PUBLIC_ANTHROPIC_API_KEY.
#
# SECURITY NOTE: a NEXT_PUBLIC_ key is embedded in the client bundle and is
# visible to anyone who loads the app. This matches the prior setup and is fine
# for a local/demo build. For a public deployment, move the AI calls behind a
# Next.js API route that reads ANTHROPIC_API_KEY server-side instead.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
NEXT_PUBLIC_ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
