# GEMINI_API_KEY: Required. The Google Gemini API key.
#
# This is a SERVER-SIDE secret. All AI calls run through Next.js API routes
# (app/api/ai/*), so the key is read server-side only and is NEVER shipped in
# the client bundle. Do NOT use a NEXT_PUBLIC_ prefix.
#
# Local dev: put this in .env.local. Production: set it in the Vercel project's
# Environment Variables (Production + Preview), then redeploy.
# (GOOGLE_API_KEY is also accepted as a fallback name.)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
